{
  "builds": [
    {
      "src": "cropstress_front/cropstress_front-main/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "cropstress_front/cropstress_front-main/$1"
    }
  ]
}